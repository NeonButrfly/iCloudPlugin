{
  "name": "icloudplugin-remote-mcp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "access:plan": "node ./scripts/print-access-bootstrap.mjs",
    "deploy": "wrangler deploy",
    "deploy:plan": "node ./scripts/deploy-and-verify.mjs --plan",
    "deploy:verify": "node ./scripts/deploy-and-verify.mjs",
    "dev": "wrangler dev",
    "dev:verify": "node ./scripts/dev-and-verify.mjs",
    "mcp:verify": "node ./scripts/verify-mcp-tools.mjs",
