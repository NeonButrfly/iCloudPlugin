{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "icloudplugin-remote-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "MCP_ROUTE": "/mcp",
    "DOWNLOAD_ROUTE_PREFIX": "/download"
  }
}
