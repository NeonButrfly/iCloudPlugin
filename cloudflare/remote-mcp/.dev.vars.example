ORIGIN_BASE_URL=https://clouddrive.neonbutterfly.net
ORIGIN_API_TOKEN=change-me-origin-token
# For ChatGPT Developer mode, leave WORKER_API_TOKEN unset so the Worker runs in
# origin-only mode and only the Worker-to-origin hop uses bearer auth.
# WORKER_API_TOKEN=change-me-worker-token
REMOTE_MCP_PUBLIC_BASE_URL=https://icloudplugin-remote-mcp.example.workers.dev
# Optional verifier-only header bundle for Access or another front door:
# REMOTE_MCP_VERIFY_HEADERS_JSON={"CF-Access-Client-Id":"...","CF-Access-Client-Secret":"..."}
