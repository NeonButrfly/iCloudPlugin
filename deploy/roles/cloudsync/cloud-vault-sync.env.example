# Optional storage-host overrides for /usr/local/bin/cloud-vault-sync.sh
#
# Copy to /etc/default/cloud-vault-sync on the storage host and edit as needed.

# Enable Gmail mailbox export alongside the Google Drive mirror syncs.
GMAIL_EXPORT_ENABLED=false

# Per-account Gmail authorized-user JSON files. These must be Gmail-scoped
# OAuth credentials with refresh tokens, not bare Drive-only rclone tokens.
GMAIL_GOOGLE_1_AUTH_FILE=/home/kay/.config/cloud-vault/google1-gmail-authorized-user.json
GMAIL_GOOGLE_2_AUTH_FILE=/home/kay/.config/cloud-vault/google2-gmail-authorized-user.json

# Optional Gmail export tuning.
GMAIL_GOOGLE_1_ACCOUNT=kaymayers9@gmail.com
GMAIL_GOOGLE_2_ACCOUNT=keifmayers@gmail.com
GMAIL_EXPORT_QUERY=-in:chats -in:spam -in:trash
GMAIL_DOWNLOAD_ATTACHMENTS=true
GMAIL_MAX_RESULTS_PER_RUN=500
